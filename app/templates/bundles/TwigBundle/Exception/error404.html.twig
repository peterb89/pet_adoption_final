{% extends 'base.html.twig' %}

{% block title %}Page Not Found - PetAdopt{% endblock %}

{% block stylesheets %}
<style>
    .error-page {
        min-height: 60vh;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 60px 20px;
    }

    .error-page .error-code {
        font-size: 6rem;
        font-weight: 700;
        color: #6dbf9e;
        line-height: 1;
        margin-bottom: 12px;
        letter-spacing: -2px;
    }

    .error-page .error-icon {
        font-size: 4rem;
        color: #6dbf9e;
        margin-bottom: 16px;
    }

    .error-page h1 {
        font-size: 1.8rem;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 12px;
    }

    .error-page p {
        font-size: 1rem;
        color: #777;
        max-width: 500px;
        margin: 0 auto 28px;
        line-height: 1.6;
    }

    .error-page .actions {
        display: flex;
        gap: 12px;
        justify-content: center;
    }
</style>
{% endblock %}

{% block body %}

<div class="error-page">
    <div>
        <div class="error-icon"><i class="bi bi-search"></i></div>
        <div class="error-code">404</div>
        <h1>Page Not Found</h1>
        <p>The page you're looking for doesn't exist or may have been moved. Don't worry — your future best friend is still waiting for you.</p>
        <div class="actions">
            <a href="{{ path('home') }}" class="btn btn-mint px-4 py-2">Back to Home</a>
            <a href="{{ path('animal_index') }}" class="btn btn-outline-mint px-4 py-2">Browse Pets</a>
        </div>
    </div>
</div>

{% endblock %}
