<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}PetAdopt{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --mint: #6dbf9e; --mint-dark: #57aa88; --ink: #1a1a1a; --muted: #6c757d; --soft: #f6fbf8; --border: #e6eee9; }
        body { font-family: 'Segoe UI', Arial, sans-serif; color: var(--ink); background: #fff; }
        .navbar { background-color: #fff; border-bottom: 1px solid var(--border); padding: 14px 0; }
        .navbar-brand { font-weight: 700; font-size: 1.3rem; color: var(--ink) !important; margin-right: 2rem; }
        .navbar-brand span { color: var(--mint); }
        .nav-link { color: #444 !important; font-size: 0.92rem; }
        .nav-link:hover { color: var(--mint) !important; }
        .btn-mint { background-color: var(--mint); color: #fff; border: none; border-radius: 8px; }
        .btn-outline-mint { border: 1.5px solid var(--mint); color: var(--mint); background: transparent; border-radius: 8px; }
        footer { background-color: var(--ink); color: #aaa; padding: 48px 0 24px; margin-top: 70px; }
        footer h6 { color: #fff; font-weight: 600; margin-bottom: 14px; }
        footer a { color: #aaa; text-decoration: none; font-size: 0.88rem; }
    </style>
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% block importmap %}{{ importmap('app') }}{% endblock %}{% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('home') }}">Pet<span>Adopt</span></a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                {# The 'me-auto' class pushes the menu to the left #}
                <ul class="navbar-nav me-auto mb-2 mb-lg-0 align-items-center" style="gap: 1rem;">
                    
                    {# --- 1. DYNAMIC ELEMENTS (LOGO AND YOUR OWN LINKS) --- #}
                    {% if dynamic_nav is defined %}
                        {% for item in dynamic_nav %}
                            {% if item.location == 'header' or item.location == 'navbar' %}
                                <li class="nav-item">
                                    <a class="nav-link {{ item.cssClass|default('') }}" 
                                       style="color: var(--mint) !important; font-weight: bold;"
                                       href="{{ item.url ?: (item.routeName ? path(item.routeName) : '#') }}">
                                        {% if item.type == 'logo' and item.imageUrl %}
                                            <img src="{{ item.imageUrl }}" alt="{{ item.name }}" style="height: 30px; width: auto; vertical-align: middle;">
                                        {% else %}
                                            {{ item.name }}
                                        {% endif %}
                                    </a>
                                </li>
                            {% endif %}
                        {% endfor %}
                    {% endif %}

                    {# --- 2. FIXED LINKS --- #}
                    <li class="nav-item"><a class="nav-link" href="{{ path('home') }}">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('home') }}#adopt">Adopt</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('home') }}#how-it-works">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>

                {# Right side buttons #}
                <div class="d-flex gap-2 align-items-center">
                    {% if app.user %}
                        <a href="{{ path('app_profile_show') }}" class="btn btn-outline-mint btn-sm px-3">Profile</a>
                        <a href="#" class="btn btn-mint btn-sm px-3">Logout</a>
                    {% else %}
                        <a href="#" class="btn btn-outline-mint btn-sm px-3">Login</a>
                        <a href="#" class="btn btn-mint btn-sm px-3">Register</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

    <footer id="contact">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <h6>Pet<span class="text-mint">Adopt</span></h6>
                    <p>We connect pets in need with families ready to adopt responsibly.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="#">Home</a></li>
                        <li><a href="#">Adopt</a></li>
                        {% if dynamic_nav is defined %}
                            {% for item in dynamic_nav %}
                                {% if item.location == 'footer' %}
                                    <li><a href="{{ item.url ?: '#' }}" style="color: var(--muted);">{{ item.name }}</a></li>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Contact</h6>
                    <p class="mb-1">Email: contact@petadopt.test</p>
                </div>
            </div>
            <hr style="border-color: #333;">
            <p class="text-center mb-0" style="font-size: 0.82rem; color: #666;">© 2026 PetAdopt. All rights reserved.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>