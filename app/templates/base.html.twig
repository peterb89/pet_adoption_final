<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}PetAdopt{% endblock %}</title>

        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

        <style>
            body {
                font-family: 'Segoe UI', Arial, sans-serif;
                color: #1a1a1a;
                background: #fff;
            }

            .navbar {
                background-color: #fff;
                border-bottom: 1px solid #eee;
                padding: 14px 0;
            }

            .navbar-brand {
                font-weight: 700;
                font-size: 1.3rem;
                color: #1a1a1a !important;
                letter-spacing: -0.5px;
            }

            .navbar-brand span {
                color: #6dbf9e;
            }

            .nav-link {
                color: #444 !important;
                font-size: 0.92rem;
            }

            .nav-link:hover {
                color: #6dbf9e !important;
            }

            .btn-mint {
                background-color: #6dbf9e;
                color: #fff;
                border: none;
                border-radius: 6px;
            }

            .btn-mint:hover {
                background-color: #57aa88;
                color: #fff;
            }

            .btn-outline-mint {
                border: 1.5px solid #6dbf9e;
                color: #6dbf9e;
                background: transparent;
                border-radius: 6px;
            }

            .btn-outline-mint:hover {
                background: #6dbf9e;
                color: #fff;
            }

            footer {
                background-color: #1a1a1a;
                color: #aaa;
                padding: 48px 0 24px;
                margin-top: 60px;
            }

            footer h6 {
                color: #fff;
                font-weight: 600;
                margin-bottom: 14px;
                font-size: 0.95rem;
            }

            footer a {
                color: #aaa;
                text-decoration: none;
                font-size: 0.88rem;
            }

            footer a:hover {
                color: #6dbf9e;
            }

            footer p {
                font-size: 0.88rem;
            }
        </style>

        {% block stylesheets %}{% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>

        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container">
                <a class="navbar-brand" href="{{ path('home') }}">
                    Pet<span>Adopt</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item"><a class="nav-link" href="{{ path('home') }}">Home</a></li>
                        <li class="nav-item"><a class="nav-link" href="{{ path('animal_index') }}">Adopt</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">About Us</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">How It Works</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Contact</a></li>
                    </ul>
                    <div class="d-flex gap-2">
                        <a href="#" class="btn btn-outline-mint btn-sm px-3">Login</a>
                        <a href="#" class="btn btn-mint btn-sm px-3">Register</a>
                    </div>
                </div>
            </div>
        </nav>

        {% block body %}{% endblock %}

        <footer>
            <div class="container">
                <div class="row mb-4">
                    <div class="col-md-3 mb-3">
                        <h6>Pet<span style="color: #6dbf9e;">Adopt</span></h6>
                        <p>We connect pets in need with loving families across the country.</p>
                    </div>
                    <div class="col-md-3 mb-3">
                        <h6>Quick Links</h6>
                        <ul class="list-unstyled">
                            <li><a href="{{ path('home') }}">Home</a></li>
                            <li><a href="{{ path('animal_index') }}">Adopt</a></li>
                            <li><a href="#">About Us</a></li>
                            <li><a href="#">Contact</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 mb-3">
                        <h6>Resources</h6>
                        <ul class="list-unstyled">
                            <li><a href="#">Adoption Process</a></li>
                            <li><a href="#">Pet Care Tips</a></li>
                            <li><a href="#">FAQs</a></li>
                        </ul>
                    </div>
                    <div class="col-md-3 mb-3">
                        <h6>Stay Updated</h6>
                        <p>Subscribe to our newsletter for updates.</p>
                        <div class="input-group input-group-sm">
                            <input type="email" class="form-control" placeholder="Enter your email">
                            <button class="btn btn-mint">Subscribe</button>
                        </div>
                    </div>
                </div>
                <hr style="border-color: #333;">
                <p class="text-center mb-0" style="font-size: 0.82rem; color: #666;">© 2025 PetAdopt. All rights reserved.</p>
            </div>
        </footer>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>