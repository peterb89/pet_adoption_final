<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}PetAdopt{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --mint: #6dbf9e;
            --mint-dark: #57aa88;
            --ink: #1a1a1a;
            --muted: #6c757d;
            --soft: #f6fbf8;
            --border: #e6eee9;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            color: var(--ink);
            background: #fff;
        }

        .navbar {
            background-color: #fff;
            border-bottom: 1px solid var(--border);
            padding: 14px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
            color: var(--ink) !important;
            letter-spacing: -0.5px;
        }

        .navbar-brand span,
        .text-mint {
            color: var(--mint);
        }

        .nav-link {
            color: #444 !important;
            font-size: 0.92rem;
        }

        .nav-link:hover {
            color: var(--mint) !important;
        }

        .btn-mint {
            background-color: var(--mint);
            color: #fff;
            border: none;
            border-radius: 8px;
        }

        .btn-mint:hover {
            background-color: var(--mint-dark);
            color: #fff;
        }

        .btn-outline-mint {
            border: 1.5px solid var(--mint);
            color: var(--mint);
            background: transparent;
            border-radius: 8px;
        }

        .btn-outline-mint:hover {
            background: var(--mint);
            color: #fff;
        }

        .page-hero {
            background: linear-gradient(135deg, #f6fbf8 0%, #eef8f2 100%);
            border-bottom: 1px solid var(--border);
            padding: 52px 0;
            margin-bottom: 40px;
        }

        .content-card {
            border: 1px solid var(--border);
            border-radius: 18px;
            background: #fff;
            box-shadow: 0 12px 30px rgba(30, 70, 50, 0.06);
        }

        .pet-card {
            height: 100%;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .pet-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 16px 36px rgba(30, 70, 50, 0.12);
        }

        .pet-placeholder {
            height: 210px;
            background: linear-gradient(135deg, #dff3ea, #f7efe4);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--mint-dark);
            font-size: 3rem;
        }

        .badge-soft {
            background: #eef8f2;
            color: #2f7d5d;
            border: 1px solid #d6eee1;
            font-weight: 600;
        }

        .form-control,
        .form-select {
            border-radius: 10px;
            border-color: var(--border);
            padding: 10px 12px;
        }

        .form-control:focus,
        .form-select:focus {
            border-color: var(--mint);
            box-shadow: 0 0 0 0.2rem rgba(109, 191, 158, 0.18);
        }

        footer {
            background-color: var(--ink);
            color: #aaa;
            padding: 48px 0 24px;
            margin-top: 70px;
        }

        footer h6 {
            color: #fff;
            font-weight: 600;
            margin-bottom: 14px;
            font-size: 0.95rem;
        }

        footer a {
            color: #aaa;
            text-decoration: none;
            font-size: 0.88rem;
        }

        footer a:hover {
            color: var(--mint);
        }
    </style>

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="{{ path('home') }}">Pet<span>Adopt</span></a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link" href="{{ path('home') }}">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('animal_index') }}">Adopt</a></li>
                    <li class="nav-item"><a class="nav-link" href="#how-it-works">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link" href="#contact">Contact</a></li>
                </ul>

                <div class="d-flex gap-2">
                    {% if app.user %}
                        <a href="{{ path('app_profile_show') }}" class="btn btn-outline-mint btn-sm px-3">Profile</a>
                        <a href="{{ path('app_logout') }}" class="btn btn-mint btn-sm px-3">Logout</a>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-outline-mint btn-sm px-3">Login</a>
                        <a href="{{ path('app_register') }}" class="btn btn-mint btn-sm px-3">Register</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

    <footer id="contact">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <h6>Pet<span class="text-mint">Adopt</span></h6>
                    <p>We connect pets in need with families ready to adopt responsibly.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
                        <li><a href="{{ path('home') }}">Home</a></li>
                        <li><a href="{{ path('animal_index') }}">Adopt</a></li>
                        <li><a href="#how-it-works">How It Works</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Contact</h6>
                    <p class="mb-1">Email: contact@petadopt.test</p>
                    <p class="mb-0">Support available Monday to Friday.</p>
                </div>
            </div>
            <hr style="border-color: #333;">
            <p class="text-center mb-0" style="font-size: 0.82rem; color: #666;">© 2026 PetAdopt. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
