<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}PetAdopt{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        :root {
            --mint: #6dbf9e;
            --mint-dark: #57aa88;
            --ink: #1a1a1a;
            --muted: #6c757d;
            --soft: #f6fbf8;
            --border: #e6eee9;
        }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            color: var(--ink);
            background: #fff;
        }

        .navbar {
            background-color: #fff;
            border-bottom: 1px solid var(--border);
            padding: 14px 0;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
            color: var(--ink) !important;
            letter-spacing: -0.5px;
        }

        .navbar-brand span,
        .text-mint {
            color: var(--mint);
        }

        .nav-link {
            color: #444 !important;
            font-size: 0.92rem;
        }

        .nav-link:hover {
            color: var(--mint) !important;
        }

        .btn-mint {
            background-color: var(--mint);
            color: #fff;
            border: none;
            border-radius: 8px;
        }

        .btn-mint:hover {
            background-color: var(--mint-dark);
            color: #fff;
        }

        .btn-outline-mint {
            border: 1.5px solid var(--mint);
            color: var(--mint);
            background: transparent;
            border-radius: 8px;
        }

        .btn-outline-mint:hover {
            background: var(--mint);
            color: #fff;
        }

        footer {
            background-color: var(--ink);
            color: #aaa;
            padding: 48px 0 24px;
            margin-top: 70px;
        }

        footer h6 {
            color: #fff;
            font-weight: 600;
            margin-bottom: 14px;
            font-size: 0.95rem;
        }

        footer a {
            color: #aaa;
            text-decoration: none;
            font-size: 0.88rem;
        }

        footer a:hover {
            color: var(--mint);
        }
    </style>

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" href="#">Pet<span>Adopt</span></a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
    {% for item in dynamic_nav %}
        {% if item.location == 'header' or item.location == 'navbar' %}
            <li class="nav-item">
                <a class="nav-link {{ item.cssClass }}" 
                   href="{{ item.url ? item.url : (item.routeName ? path(item.routeName) : '#') }}">
                    {% if item.type == 'logo' and item.imageUrl %}
                        <img src="{{ asset(item.imageUrl) }}" alt="{{ item.name }}" style="height: 30px;">
                    {% else %}
                        {{ item.name }}
                    {% endif %}
                </a>
            </li>
        {% endif %}
    {% endfor %}
</ul>

                <div class="d-flex gap-2">
                    
                    {% if app.user %}
                        <a href="{{ path('app_profile_show') }}" class="btn btn-outline-mint btn-sm px-3">Profile</a>
                        <a href="#" class="btn btn-mint btn-sm px-3">Logout</a>
                    {% else %}
                        <a href="#" class="btn btn-outline-mint btn-sm px-3">Login</a>
                        <a href="#" class="btn btn-mint btn-sm px-3">Register</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </nav>

    {% block body %}{% endblock %}

    <footer id="contact">
        <div class="container">
            <div class="row mb-4">
                <div class="col-md-4 mb-3">
                    <h6>Pet<span class="text-mint">Adopt</span></h6>
                    <p>We connect pets in need with families ready to adopt responsibly.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Quick Links</h6>
                    <ul class="list-unstyled">
    {% for item in dynamic_nav %}
        {% if item.location == 'footer' %}
            <li>
                <a class="{{ item.cssClass }}" 
                   href="{{ item.url ? item.url : (item.routeName ? path(item.routeName) : '#') }}">
                    {{ item.name }}
                </a>
            </li>
        {% endif %}
    {% endfor %}
</ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Contact</h6>
                    <p class="mb-1">Email: contact@petadopt.test</p>
                    <p class="text-muted" style="font-size: 0.8rem;">Support available Monday to Friday.</p>
                </div>
            </div>
            <hr style="border-color: #333;">
            <p class="text-center mb-0" style="font-size: 0.82rem; color: #666;">© 2026 PetAdopt. All rights reserved.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>