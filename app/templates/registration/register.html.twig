{% extends 'base.html.twig' %}

{% block title %}Register - PetAdopt{% endblock %}

{% block body %}
<main class="container" style="max-width: 560px; margin-top: 60px;">
    <div class="content-card p-4 p-md-5">
        <h1 class="h3 fw-bold mb-2">Create account</h1>
        <p class="text-muted mb-4">Register to manage your adoption profile.</p>

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.email, {'attr': {'class': 'form-control'}}) }}
            {{ form_row(registrationForm.plainPassword, {'attr': {'class': 'form-control'}}) }}
            <button type="submit" class="btn btn-mint w-100 mt-3">Register</button>
        {{ form_end(registrationForm) }}
    </div>
</main>
{% endblock %}
