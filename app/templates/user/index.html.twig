{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <div class="container">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
            <div>
                <h1 class="h2 mb-1">Users</h1>
                <p class="text-secondary mb-0">Manage user accounts from one place.</p>
            </div>
            <a class="btn btn-primary" href="{{ path('app_user_new') }}">Create new user</a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Id</th>
                            <th>Email</th>
                            <th>Roles</th>
                            <th>Verified</th>
                            <th>Created</th>
                            <th>Updated</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for user in users %}
                        <tr>
                            <td class="fw-semibold">{{ user.id }}</td>
                            <td>{{ user.email }}</td>
                            <td><span class="badge text-bg-secondary">{{ user.roles }}</span></td>
                            <td>
                                {% if user.isVerified %}
                                    <span class="badge text-bg-success">Yes</span>
                                {% else %}
                                    <span class="badge text-bg-warning">No</span>
                                {% endif %}
                            </td>
                            <td>{{ user.createdAt ? user.createdAt|date('Y-m-d H:i') : '' }}</td>
                            <td>{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i') : '' }}</td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a class="btn btn-outline-secondary" href="{{ path('app_user_show', {'id': user.id}) }}">View</a>
                                    <a class="btn btn-outline-primary" href="{{ path('app_user_edit', {'id': user.id}) }}">Edit</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-secondary py-4">No users found.</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
