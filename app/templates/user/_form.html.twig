{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-12">
            {{ form_row(form.email) }}
        </div>
        <div class="col-12">
            {{ form_row(form.password) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.roles) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.is_verified) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.created_at) }}
        </div>
        <div class="col-md-6">
            {{ form_row(form.updated_at) }}
        </div>
    </div>

    <div class="d-flex gap-2 mt-4">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
        <a class="btn btn-outline-secondary" href="{{ path('app_user_index') }}">Back to list</a>
    </div>
{{ form_end(form) }}
