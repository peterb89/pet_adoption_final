{% extends 'base.html.twig' %}

{% block title %}Profile: {{ profile ? profile.firstName : 'Guest' }}{% endblock %}

{% block body %}

<section class="page-hero">
    <div class="container">
        <h1 class="fw-bold mb-2">User Profile</h1>
        <p class="text-muted mb-0">Manage your adoption preferences and track your requests.</p>
    </div>
</section>

<main class="container mb-5" style="max-width: 1000px;">
    {% if profile is not null %}
        
        <div class="content-card p-4 p-md-5 mb-5">
            <div class="d-flex flex-column flex-md-row gap-4 align-items-md-center mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" 
                     style="width: 120px; height: 120px; background: var(--mint); font-size: 2.5rem;">
                    {{ profile.firstName|first }}{{ profile.lastName|first }}
                </div>

                <div class="flex-grow-1">
                    <h2 class="fw-bold mb-1">{{ profile.firstName }} {{ profile.lastName }}</h2>
                    <p class="text-muted mb-3">
                        <i class="bi bi-geo-alt"></i> {{ profile.city }}, {{ profile.address }}
                    </p>
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-mint px-4">Edit profile</a>
                </div>
            </div>

            <hr>

            <div class="row g-4 mt-2">
                <div class="col-md-4">
                    <p class="text-muted mb-1">Phone</p>
                    <p class="fw-semibold mb-0">{{ profile.phoneNumber ?? 'Not provided' }}</p>
                </div>

                <div class="col-md-4">
                    <p class="text-muted mb-1">Housing type</p>
                    <p class="fw-semibold mb-0">
                        {{ profile.housingType ? profile.housingType.name : 'Not specified' }}
                    </p>
                </div>

                <div class="col-md-12 mt-4">
                    <p class="text-muted mb-1">Motivation</p>
                    <p class="fst-italic" style="color: #555;">
                        {{ profile.motivation ?? 'No motivation text provided yet.' }}
                    </p>
                </div>
            </div>
        </div>

        <div class="content-card p-4 p-md-5">
            <h3 class="fw-bold mb-4" style="border-bottom: 2px solid var(--mint); padding-bottom: 10px;">
                My Adoption Applications (Tracking)
            </h3>

            <div class="table-responsive">
                <table class="table table-hover mt-2">
                    <thead class="table-light">
                        <tr>
                            <th>Animal</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if adoptions|length > 0 %}
                            {% for app in adoptions %}
                                <tr>
                                    <td class="fw-bold">{{ app.animal.name }}</td>
                                    <td>
                                        <span class="badge {% if app.status == 'approved' %}bg-success{% else %}bg-warning text-dark{% endif %}" style="padding: 8px 12px;">
                                            {{ app.status|upper }}
                                        </span>
                                    </td>
                                    <td class="text-muted">{{ app.createdAt|date('Y-m-d') }}</td>
                                </tr>
                            {% endfor %}
                        {% else %}
                            <tr>
                                <td colspan="3" class="text-center py-4 text-muted">
                                    You haven't applied for any animals yet.
                                </td>
                            </tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>

    {% else %}
        
        <div class="content-card p-5 text-center">
            <h2 class="h4 fw-bold">No profile found</h2>
            <p class="text-muted mb-4">
                Please create your profile data first to start adopting.
            </p>

            <a href="{{ path('app_profile_edit') }}" class="btn btn-mint">
                Create profile
            </a>
        </div>

    {% endif %}
</main>

{% endblock %}