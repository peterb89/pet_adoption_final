{% extends 'base.html.twig' %}

{% block title %}Profile - PetAdopt{% endblock %}

{% block body %}
<section class="page-hero">
    <div class="container">
        <h1 class="fw-bold mb-2">Adoption Profile</h1>
        <p class="text-muted mb-0">Keep your personal and housing information ready for adoption requests.</p>
    </div>
</section>

<main class="container" style="max-width: 900px;">
    {% if profile %}
        <div class="content-card p-4 p-md-5">
            <div class="d-flex flex-column flex-md-row gap-4 align-items-md-center mb-4">
                <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold" style="width: 120px; height: 120px; background: var(--mint); font-size: 2rem;">
                    {{ profile.firstName|first }}{{ profile.lastName|first }}
                </div>

                <div class="flex-grow-1">
                    <h2 class="fw-bold mb-1">{{ profile.firstName }} {{ profile.lastName }}</h2>
                    <p class="text-muted mb-3">{{ profile.city }}, {{ profile.address }}</p>
                    <a href="{{ path('app_profile_edit') }}" class="btn btn-mint">Edit profile</a>
                </div>
            </div>

            <hr>

            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <p class="text-muted mb-1">Phone</p>
                    <p class="fw-semibold mb-0">{{ profile.phoneNumber ?? 'Not provided' }}</p>
                </div>
                <div class="col-md-6">
                    <p class="text-muted mb-1">Housing type</p>
                    <p class="fw-semibold mb-0">{{ profile.housingType ? profile.housingType.name : 'Not provided' }}</p>
                </div>
            </div>
        </div>
    {% else %}
        <div class="content-card p-5 text-center">
            <h2 class="h4 fw-bold">No profile found</h2>
            <p class="text-muted mb-0">Create a profile record from the admin panel or adapt the controller to create one for the logged user.</p>
        </div>
    {% endif %}
</main>
{% endblock %}
