{% extends 'base.html.twig' %}

{% block title %}Profile: {{ profile ? profile.firstName : 'Guest' }}{% endblock %}

{% block body %}
<div class="container" style="max-width: 1000px; margin: 40px auto; font-family: sans-serif;">
    {% if profile is not null %}
    <div style="display: flex; gap: 30px; align-items: center; background: #f8f9fa; padding: 30px; border-radius: 12px; border: 1px solid #eee;">
        <div style="width: 150px; height: 150px; background: #ccc; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 60px; color: #555; border: 4px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
            {{ profile.firstName|first }}{{ profile.lastName|first }}
        </div>

        <div style="flex: 1;">
            <h1 style="margin: 0; font-size: 2.5rem; color: #1a1a1a;">{{ profile.firstName }} {{ profile.lastName }}</h1>
            <p style="color: #666; font-size: 1.1rem; margin: 5px 0 15px 0;">
                <i class="bi bi-geo-alt"></i> {{ profile.city }}, {{ profile.address }}
            </p>
            <a href="{{ path('app_profile_edit') }}" class="btn btn-success" style="background-color: #2ea44f; border: none; padding: 10px 25px; font-weight: bold; border-radius: 8px;">Edit Profile</a>
        </div>
    </div>

    <div class="row mt-5">
        <div class="col-md-4">
            <h3 style="border-bottom: 2px solid #6dbf9e; padding-bottom: 10px;">About</h3>
            <p><strong>Housing Type:</strong> {{ profile.housingType ? profile.housingType.name : 'Not specified' }}</p>
            <p><strong>Phone:</strong> {{ profile.phoneNumber ?? 'Not specified' }}</p>
            
           
            <div class="mt-4">
                <h3 style="border-bottom: 2px solid #6dbf9e; padding-bottom: 10px;">Motivation</h3>
                <p style="font-style: italic; color: #555;">
                    {{ profile.motivation ?? 'No motivation text provided yet.' }}
                </p>
            </div>
        </div>
        
        <div class="col-md-8">
            <h3 style="border-bottom: 2px solid #6dbf9e; padding-bottom: 10px;">My Adoption Applications (Tracking)</h3>
            <table class="table table-hover mt-3">
                <thead class="table-light">
                    <tr>
                        <th>Animal</th>
                        <th>Status</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    {% if adoptions|length > 0 %}
                        {% for app in adoptions %}
                            <tr>
                                <td>{{ app.animal.name }}</td>
                                <td>
                                    <span class="badge {% if app.status == 'approved' %}bg-success{% else %}bg-warning{% endif %}" style="padding: 8px 12px; color: {% if app.status == 'approved' %}white{% else %}black{% endif %};">
                                        {{ app.status|upper }}
                                    </span>
                                </td>
                                <td>{{ app.createdAt|date('Y-m-d') }}</td>
                            </tr>
                        {% endfor %}
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted">No applications found.</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    {% else %}
        <div class="alert alert-warning mt-5">
            <h2>No profile found!</h2>
            <p>Please go to the <a href="{{ path('admin') }}">Admin Panel</a> to create your profile data first.</p>
        </div>
    {% endif %}
</div>
{% endblock %}