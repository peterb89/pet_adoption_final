{% extends 'base.html.twig' %}

{% block title %}Settings - Profile{% endblock %}

{% block body %}
<div style="max-width: 1000px; margin: 40px auto; display: flex; gap: 40px; font-family: sans-serif;">
    <!-- Github-style menu on the left -->
    <div style="width: 250px;">
        <ul style="list-style: none; padding: 0;">
            <li style="padding: 10px; background: #f6f8fa; border-left: 3px solid #fd8c73; font-weight: bold;">Public profile</li>
            <li style="padding: 10px; color: #57606a;">Account settings</li>
            <li style="padding: 10px; color: #57606a;">Security</li>
        </ul>
    </div>

    <!-- Editor section on the right -->
    <div style="flex: 1;">
        <h2 style="border-bottom: 1px solid #d0d7de; padding-bottom: 10px;">Public profile</h2>
        
        {{ form_start(form) }}
            <div style="margin-bottom: 20px;">
                {{ form_rest(form) }}
            </div>
            
            <hr style="border: 0; border-top: 1px solid #d0d7de; margin: 20px 0;">
            
            <button type="submit" style="background-color: #2ea44f; color: white; border: 1px solid rgba(27,31,35,0.15); border-radius: 6px; padding: 10px 20px; font-weight: bold; cursor: pointer;">
                Update Profile
            </button>
            <a href="{{ path('app_profile_show') }}" style="margin-left: 15px; color: #0969da; text-decoration: none;">Cancel</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}