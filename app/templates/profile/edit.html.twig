{% extends 'base.html.twig' %}

{% block title %}Edit Profile - PetAdopt{% endblock %}

{% block body %}
<section class="page-hero">
    <div class="container">
        <h1 class="fw-bold mb-2">Edit Profile</h1>
        <p class="text-muted mb-0">Update the information used during the adoption process.</p>
    </div>
</section>

<main class="container" style="max-width: 900px;">
    {% if profile %}
        <div class="content-card p-4 p-md-5">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-6">{{ form_row(form.firstName) }}</div>
                    <div class="col-md-6">{{ form_row(form.lastName) }}</div>
                    <div class="col-md-6">{{ form_row(form.phoneNumber) }}</div>
                    <div class="col-md-6">{{ form_row(form.city) }}</div>
                    <div class="col-12">{{ form_row(form.address) }}</div>
                    <div class="col-12">{{ form_row(form.housingType) }}</div>
                    <div class="col-12">{{ form_row(form.motivation) }}</div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-mint px-4">Save changes</button>
                    <a href="{{ path('app_profile_show') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    {% else %}
        <div class="content-card p-5 text-center">
            <h2 class="h4 fw-bold">No profile found</h2>
            <p class="text-muted mb-0">There is no profile available to edit.</p>
        </div>
    {% endif %}
</main>
{% endblock %}
