{% extends 'base.html.twig' %}

{% block title %}{{ animal.name }} - PetAdopt{% endblock %}

{% block body %}
<section class="page-hero">
    <div class="container">
        <a href="{{ path('animal_index') }}" class="btn btn-outline-mint btn-sm mb-3">
            <i class="bi bi-arrow-left"></i> Back to animals
        </a>
        <h1 class="fw-bold mb-2">{{ animal.name }}</h1>
        <p class="text-muted mb-0">Review this pet's basic information before applying.</p>
    </div>
</section>

<main class="container">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="content-card overflow-hidden">
                <div class="pet-placeholder" style="height: 360px;">
                    <i class="bi bi-heart-pulse"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="content-card p-4 p-lg-5">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div>
                        <span class="badge badge-soft mb-2">{{ animal.species ? animal.species.name : 'Pet' }}</span>
                        <h2 class="h3 fw-bold mb-0">{{ animal.name }}</h2>
                    </div>
                    <span class="badge text-bg-light border">{{ animal.status|capitalize }}</span>
                </div>

                <dl class="row mb-4">
                    <dt class="col-sm-4 text-muted">Breed</dt>
                    <dd class="col-sm-8">{{ animal.breed ?? 'Unknown' }}</dd>

                    <dt class="col-sm-4 text-muted">Age</dt>
                    <dd class="col-sm-8">{{ animal.age ? animal.age ~ ' years old' : 'Unknown' }}</dd>

                    <dt class="col-sm-4 text-muted">Location</dt>
                    <dd class="col-sm-8">{{ animal.location ?? 'Unknown' }}</dd>

                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">{{ animal.status|capitalize }}</dd>
                </dl>

                <a href="{{ path('app_profile_edit') }}" class="btn btn-mint px-4">
                    Prepare adoption profile
                </a>
            </div>
        </div>
    </div>
</main>
{% endblock %}
